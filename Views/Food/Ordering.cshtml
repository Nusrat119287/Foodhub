@model Turbo_Food_Main.ViewModels.OrderPageViewModel
@{
    ViewData["Title"] = "Food Ordering";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Food Ordering</h3>
        <a asp-action="Search" class="btn btn-outline-primary">Back to Search</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Basket Items</div>
                <div class="card-body">
                    @if (!Model.CartItems.Any())
                    {
                        <div class="alert alert-warning mb-0">Your basket is empty.</div>
                    }
                    else
                    {
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                <div>
                                    <strong>@item.Name</strong>
                                    <div class="small text-muted">Unit: BDT @item.UnitPrice</div>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <form asp-action="UpdateCart" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.ItemId" />
                                        <input type="number" class="form-control form-control-sm" style="width:80px" name="quantity" value="@item.Quantity" min="0" />
                                        <button class="btn btn-sm btn-outline-primary">Update</button>
                                    </form>
                                    <form asp-action="RemoveFromCart" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.ItemId" />
                                        <button class="btn btn-sm btn-outline-danger">X</button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white fw-bold">Order Summary</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between"><span>SubTotal:</span><strong>BDT @Model.Subtotal</strong></div>
                    <div class="d-flex justify-content-between"><span>Discount:</span><span>-@Model.Discount</span></div>
                    <div class="d-flex justify-content-between"><span>Delivery Fee:</span><span>@Model.DeliveryFee</span></div>
                    <hr />
                    <div class="d-flex justify-content-between fs-5"><span>Total:</span><strong>BDT @Model.GrandTotal</strong></div>

                    <form asp-action="Checkout" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <textarea name="specialInstructions" class="form-control mb-2" rows="3" placeholder="Special instructions (optional)"></textarea>
                        <button class="btn btn-success w-100" @(Model.CartItems.Any() ? null : "disabled")>Checkout!</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

