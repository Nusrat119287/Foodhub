@model Turbo_Food_Main.ViewModels.FoodSearchViewModel
@{
    ViewData["Title"] = "Food Search";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-3 mt-2">
    <div class="col-lg-3">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold">Availability</div>
            <div class="card-body">
                <form method="get" asp-action="Search">
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="sortBy" value="@Model.SortBy" />
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="availableOnly" name="availableOnly" value="true" @(Model.AvailableOnly ? "checked" : "") />
                        <label class="form-check-label" for="availableOnly">Show available only</label>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Min Price</label>
                        <input class="form-control" name="minPrice" value="@Model.MinPrice" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Max Price</label>
                        <input class="form-control" name="maxPrice" value="@Model.MaxPrice" />
                    </div>
                    <button class="btn btn-success w-100" type="submit">Check Availability</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header fw-bold">Categories</div>
            <div class="list-group list-group-flush">
                <a asp-action="Search" asp-route-q="@Model.Query" asp-route-sortBy="@Model.SortBy" class="list-group-item list-group-item-action @(string.IsNullOrWhiteSpace(Model.Category) ? "active" : "")">All</a>
                @foreach (var cat in Model.Categories)
                {
                    <a asp-action="Search" asp-route-q="@Model.Query" asp-route-category="@cat" asp-route-sortBy="@Model.SortBy" class="list-group-item list-group-item-action @(Model.Category == cat ? "active" : "")">@cat</a>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        @if (TempData["OrderStatus"] is string message && !string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-info">@message</div>
        }

        <form method="get" asp-action="Search" class="mb-3 d-flex gap-2">
            <input class="form-control" name="q" value="@Model.Query" placeholder="Search from menu..." />
            <select class="form-select w-auto" name="sortBy">
                <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Sort by Pricing (Low to High)</option>
                <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Sort by Pricing (High to Low)</option>
                <option value="name_asc" selected="@(Model.SortBy == "name_asc")">Sort by Name</option>
            </select>
            <input type="hidden" name="category" value="@Model.Category" />
            <input type="hidden" name="availableOnly" value="@Model.AvailableOnly" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>

        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold">Add New Menu Item</div>
            <div class="card-body">
                <form asp-action="AddMenuItem" method="post" enctype="multipart/form-data" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-md-6"><input class="form-control" name="name" placeholder="Item name" required /></div>
                    <div class="col-md-6"><input class="form-control" name="category" placeholder="Category" required /></div>
                    <div class="col-12"><input class="form-control" name="description" placeholder="Description" required /></div>
                    <div class="col-md-4"><input class="form-control" name="price" placeholder="Price" required /></div>
                    <div class="col-md-8"><input class="form-control" type="file" name="imageFile" accept="image/*" /></div>
                    <div class="col-12 form-check ms-2">
                        <input class="form-check-input" type="checkbox" id="availability" name="availability" value="true" checked />
                        <label class="form-check-label" for="availability">Available</label>
                    </div>
                    <div class="col-12"><button class="btn btn-dark">Add Menu Item</button></div>
                </form>
                <div class="small text-muted mt-2">Upload an image directly from your device. If not uploaded, placeholder will be shown.</div>
            </div>
        </div>

        <h3 class="mb-3">@(!string.IsNullOrWhiteSpace(Model.Category) ? Model.Category : "Menu")</h3>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-warning">No food items matched your filters.</div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                var imageSrc = string.IsNullOrWhiteSpace(item.ImagePath) ? "https://via.placeholder.com/180x120?text=Add+Image" : item.ImagePath;
                <div class="card shadow-sm mb-3 food-card">
                    <div class="card-body d-flex justify-content-between gap-3">
                        <div>
                            <h5 class="mb-1">@item.Name</h5>
                            <div class="small text-muted mb-2">@item.Description</div>
                            <div class="small mb-2"><span class="badge bg-secondary">@item.Category</span> <span class="badge @(item.Availability ? "bg-success" : "bg-danger")">@(item.Availability ? "Available" : "Unavailable")</span></div>
                            <div class="fw-bold text-success">BDT @item.Price</div>
                        </div>
                        <div class="text-end">
                            <img src="@imageSrc" class="food-image mb-2" alt="@item.Name" />
                            <form asp-action="AddToCart" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.ItemId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <input type="number" class="form-control form-control-sm qty-box" name="quantity" value="1" min="1" />
                                <button class="btn btn-sm btn-primary" type="submit">Add +</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        <a asp-action="Review" class="btn btn-outline-secondary mt-2">Go to Food Review Page</a>
    </div>

    <div class="col-lg-3">
        <div class="card shadow-sm basket-sticky">
            <div class="card-header bg-success text-white fw-bold">My Basket</div>
            <div class="card-body">
                @if (!Model.CartItems.Any())
                {
                    <div class="text-muted small">No items in basket yet.</div>
                }
                else
                {
                    @foreach (var c in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between small mb-2">
                            <div><strong>@c.Quantity x</strong> @c.Name</div>
                            <div>BDT @c.LineTotal</div>
                        </div>
                    }
                }

                <hr />
                <div class="d-flex justify-content-between"><span>SubTotal:</span><strong>BDT @Model.Subtotal</strong></div>
                <div class="d-flex justify-content-between"><span>Discount:</span><span>-@Model.Discount</span></div>
                <div class="d-flex justify-content-between"><span>Delivery Fee:</span><span>@Model.DeliveryFee</span></div>
                <div class="d-flex justify-content-between mt-2 fs-5"><span>Total:</span><strong>BDT @Model.GrandTotal</strong></div>
                <a asp-action="Ordering" class="btn btn-success w-100 mt-3">Checkout!</a>
            </div>
        </div>
    </div>
</div>

<style>
    .food-card .food-image {
        width: 180px;
        height: 120px;
        object-fit: cover;
        border-radius: 10px;
    }
    .qty-box {
        width: 72px;
    }
    .basket-sticky {
        position: sticky;
        top: 90px;
    }
</style>

